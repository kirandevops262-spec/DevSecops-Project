# Terraform provider binaries and plugin cache
**/.terraform/
**/.terraform.lock.hcl

# Terraform state files — stored remotely in S3
*.tfstate
*.tfstate.*
*.tfplan

# Terraform variable files that may contain secrets
*.tfvars
!variables.tfvars

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc

# macOS
.DS_Store
